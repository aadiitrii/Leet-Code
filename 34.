int left = 0, right = nums.size() - 1;
vector<int> result = {-1, -1};
while (left <= right) {
int mid = left + (right - left) / 2;
if (nums[mid] == target) {
int first = mid, last = mid;
while (first > 0 && nums[first - 1] == target) {
first--;
}
while (last < nums.size() - 1 && nums[last + 1] == 
target) {
last++;
}
return {first, last};
}
else if (nums[mid] < target) {
left = mid + 1;
}
else {
right = mid - 1;
}
}
return result; 
}
